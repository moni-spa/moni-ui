{
  "name": "@moni-spa/moni-ui",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Design system unificado para Moni — Material Design 3 Expressive, mobile-first.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "customElements": "custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web-components": {
      "types": "./dist/web-components.d.ts",
      "import": "./dist/web-components.js"
    },
    "./styles": "./dist/styles/index.css",
    "./components/*.ts": "./src/components/*.ts",
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./actions/*": {
      "types": "./dist/actions/*.d.ts",
      "import": "./dist/actions/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "custom-elements.json",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moni-spa/moni-ui.git"
  },
  "bugs": {
    "url": "https://github.com/moni-spa/moni-ui/issues"
  },
  "homepage": "https://github.com/moni-spa/moni-ui#readme",
  "peerDependencies": {
    "svelte": "^5.55.2",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "gsap": "^3.12.7",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@tailwindcss/vite": "^4.3.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "analyze": "custom-elements-manifest analyze",
    "test": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  }
}
